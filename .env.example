# AutoCore reads this file locally from the project root.
# Do not paste secrets into chat. Copy this to .env and fill only the services you want.

# Deployment mode. Use public for an internet-facing release/demo.
# AUTOCORE_MODE=public
# AUTOCORE_HOST=127.0.0.1
# AUTOCORE_PORT=8787
# AUTOCORE_STATIC_DIR=dist
# AUTOCORE_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Required if you bind live mode to a network host.
# AUTOCORE_API_TOKEN=

# Local live audit target.
# AUTOCORE_PROJECT_ROOT=

# Runs project scripts such as npm build/test or pytest. Use only with repos you trust.
# AUTOCORE_TRUST_PROJECT_SCRIPTS=0

# Optional Docker-contained execution for eligible safe Python static checks.
# Requires Docker installed and the Docker daemon running.
# AUTOCORE_ENABLE_DOCKER_CONTAINMENT=0

# Planner provider. Offline requires no key.
# AUTOCORE_PROVIDER=offline
# AUTOCORE_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1
# AUTOCORE_PROVIDER=groq
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# AUTOCORE_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

# GitHub read-only metadata. Prefer a fine-scoped token for the repos you want to inspect.
# GITHUB_TOKEN=

# Slack read-only channel context.
# SLACK_BOT_TOKEN=
# SLACK_USER_TOKEN=

# Linear or Jira read-only work tracker context.
# LINEAR_API_KEY=
# JIRA_BASE_URL=
# JIRA_API_TOKEN=

# Google Drive / Docs read-only metadata.
# GOOGLE_APPLICATION_CREDENTIALS=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Cloud/deploy/runtime log metadata.
# AWS_PROFILE=
# AWS_ACCESS_KEY_ID=
# VERCEL_TOKEN=
# AZURE_CLIENT_ID=
